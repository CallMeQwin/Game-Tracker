<Window x:Class="ValorantTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Valorant Tracker" Height="640" Width="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" MinWidth="380" MinHeight="400">
    <StackPanel Margin="24">
        <TextBlock Text="Current Status" FontSize="12" Foreground="Gray"/>
        <TextBlock x:Name="StatusText" Text="..." FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <RadioButton x:Name="TodayRadio" Content="Today" GroupName="Period"
                         Checked="Period_Changed" Margin="0,0,16,0"/>
            <RadioButton x:Name="WeekRadio" Content="This Week" GroupName="Period"
                         Checked="Period_Changed" Margin="0,0,16,0"/>
            <RadioButton x:Name="MonthRadio" Content="This Month" GroupName="Period"
                         Checked="Period_Changed"/>
        </StackPanel>

        <TextBlock Text="Active" FontSize="12" Foreground="Gray"/>
        <TextBlock x:Name="ActiveText" Text="0h 0m" FontSize="24" Margin="0,0,0,12"/>

        <TextBlock Text="Idle (in menus)" FontSize="12" Foreground="Gray"/>
        <TextBlock x:Name="IdleText" Text="0h 0m" FontSize="24" Margin="0,0,0,20"/>

        <TextBlock x:Name="SessionsHeader" Text="Timeline" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
        <Border x:Name="TimelineBorder" BorderBrush="LightGray" BorderThickness="1" CornerRadius="6">
            <ScrollViewer x:Name="TimelineScroll" Height="320" VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="TimelineCanvas" Background="Transparent"/>
            </ScrollViewer>
        </Border>
    </StackPanel>
</Window>
