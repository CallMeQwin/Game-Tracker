<Window x:Class="ValorantTracker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Valorant Tracker" Height="700" Width="1040"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" MinWidth="820" MinHeight="560"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="{StaticResource InkBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Caption bar -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource HairlineBrush}"
                    BorderThickness="0,0,0,1" MouseLeftButtonDown="CaptionBar_MouseLeftButtonDown">
                <Grid Margin="14,0,6,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ClockText" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource MonoLabel}"
                               Margin="0,0,16,0" Text="--:--:--"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="MinimizeButton" Style="{StaticResource CaptionButtonStyle}" Content="&#x2013;" Click="Minimize_Click"/>
                        <Button x:Name="CloseButton" Style="{StaticResource CaptionCloseButtonStyle}" Content="&#x2715;" Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: sidebar + main content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== Sidebar ===== -->
                <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                        BorderBrush="{StaticResource HairlineBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="20,24,20,20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Style="{StaticResource EyebrowLabel}" Text="VALORANT"/>
                            <TextBlock Text="TRACKER" FontFamily="{StaticResource DisplayFont}" FontSize="22"
                                       Foreground="{StaticResource TextBrush}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Border Grid.Row="1" Height="1" Background="{StaticResource HairlineBrush}" Margin="0,0,0,20"/>

                        <!-- Status readout, framed by target-lock corner brackets -->
                        <Grid Grid.Row="2" Margin="0,0,0,20">
                            <Grid Margin="4">
                                <Path Style="{StaticResource CornerBracket}" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                <Path Style="{StaticResource CornerBracket}" HorizontalAlignment="Right" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform><RotateTransform Angle="90"/></Path.RenderTransform>
                                </Path>
                                <Path Style="{StaticResource CornerBracket}" HorizontalAlignment="Right" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform><RotateTransform Angle="180"/></Path.RenderTransform>
                                </Path>
                                <Path Style="{StaticResource CornerBracket}" HorizontalAlignment="Left" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform><RotateTransform Angle="270"/></Path.RenderTransform>
                                </Path>

                                <StackPanel Margin="16,14" Orientation="Horizontal">
                                    <Grid Width="14" Height="14" Margin="0,3,10,0" VerticalAlignment="Top">
                                        <Ellipse x:Name="PulseRing" Width="10" Height="10" Fill="{StaticResource ActiveBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0"
                                                 RenderTransformOrigin="0.5,0.5">
                                            <Ellipse.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Ellipse.RenderTransform>
                                        </Ellipse>
                                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="{StaticResource OffBrush}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource EyebrowLabel}" Text="CURRENT STATUS"/>
                                        <TextBlock x:Name="StatusText" Text="..." FontFamily="{StaticResource DisplayFont}" FontSize="16"
                                                   Foreground="{StaticResource TextBrush}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Border Grid.Row="3" Height="1" Background="{StaticResource HairlineBrush}" Margin="0,0,0,12"/>

                        <!-- Section nav -->
                        <StackPanel Grid.Row="4">
                            <RadioButton x:Name="NavOverview" Content="OVERVIEW" GroupName="Section"
                                         Style="{StaticResource NavItemStyle}" Checked="Section_Changed"/>
                            <RadioButton x:Name="NavTrends" Content="TRENDS" GroupName="Section"
                                         Style="{StaticResource NavItemStyle}" Checked="Section_Changed"/>
                            <RadioButton x:Name="NavHistory" Content="MATCH HISTORY" GroupName="Section"
                                         Style="{StaticResource NavItemStyle}" Checked="Section_Changed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ===== Main content ===== -->
                <Grid Grid.Column="1">

                    <!-- Overview: today's playtime + timeline -->
                    <Grid x:Name="OverviewPanel" Margin="32,28,32,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="OVERVIEW" FontFamily="{StaticResource DisplayFont}" FontSize="20"
                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="PrevDayButton" Content="&#x2039;" Style="{StaticResource CaptionButtonStyle}" Click="PrevDay_Click"/>
                                <TextBlock x:Name="SelectedDayText" Text="TODAY" Style="{StaticResource MonoLabel}" VerticalAlignment="Center"
                                           Margin="4,0" MinWidth="100" TextAlignment="Center" Cursor="Hand" MouseLeftButtonDown="SelectedDayText_Click"/>
                                <Button x:Name="NextDayButton" Content="&#x203A;" Style="{StaticResource CaptionButtonStyle}" Click="NextDay_Click"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,0,0,24">
                            <TextBlock Style="{StaticResource EyebrowLabel}" Text="PLAYTIME"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,10" VerticalAlignment="Bottom">
                                <TextBlock x:Name="PlaytimeText" Text="0h 0m" Style="{StaticResource StatNumber}"/>
                                <TextBlock x:Name="MatchCountText" Text="0 matches" Style="{StaticResource MonoLabel}"
                                           Margin="12,0,0,6" VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <Border Height="3" Width="40" Background="{StaticResource ActiveBrush}" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Style="{StaticResource EyebrowLabel}" Text="TIMELINE" Margin="0,0,0,10"/>
                            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1">
                                <ScrollViewer x:Name="TimelineScroll" VerticalScrollBarVisibility="Auto">
                                    <Canvas x:Name="TimelineCanvas" Background="Transparent"/>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- Trends: week/month aggregate + per-day bar chart -->
                    <Grid x:Name="TrendsPanel" Margin="32,28,32,28" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TRENDS" FontFamily="{StaticResource DisplayFont}" FontSize="20"
                                       Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <RadioButton x:Name="TrendWeekRadio" Content="WEEK" GroupName="Trend"
                                             Style="{StaticResource PeriodTabStyle}" Checked="TrendPeriod_Changed"/>
                                <RadioButton x:Name="TrendMonthRadio" Content="MONTH" GroupName="Trend"
                                             Style="{StaticResource PeriodTabStyle}" Checked="TrendPeriod_Changed" Margin="0"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,0,0,24">
                            <TextBlock x:Name="TrendPlaytimeLabel" Style="{StaticResource EyebrowLabel}" Text="PLAYTIME THIS WEEK"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,10" VerticalAlignment="Bottom">
                                <TextBlock x:Name="TrendPlaytimeText" Text="0h 0m" Style="{StaticResource StatNumber}"/>
                                <TextBlock x:Name="TrendMatchCountText" Text="0 matches" Style="{StaticResource MonoLabel}"
                                           Margin="12,0,0,6" VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <Border Height="3" Width="40" Background="{StaticResource ActiveBrush}" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Style="{StaticResource EyebrowLabel}" Text="PLAYTIME BY DAY" Margin="0,0,0,10"/>

                        <Border x:Name="TrendChartBorder" Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource HairlineBrush}" BorderThickness="1" Padding="16">
                            <Canvas x:Name="TrendChartCanvas" Background="Transparent"/>
                        </Border>
                    </Grid>

                    <!-- Match History: placeholder for future RR-gain tracking -->
                    <Grid x:Name="HistoryPanel" Margin="32,28,32,28" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="MATCH HISTORY" FontFamily="{StaticResource DisplayFont}" FontSize="20"
                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,20"/>
                        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource HairlineBrush}"
                                BorderThickness="1" VerticalAlignment="Top" Padding="20">
                            <StackPanel>
                                <TextBlock Text="COMING SOON" Style="{StaticResource EyebrowLabel}" Foreground="{StaticResource IdleBrush}"/>
                                <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,8,0,0"
                                           Text="Per-match results with RR gain/loss will show up here once ranked tracking is wired up."/>
                            </StackPanel>
                        </Border>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
